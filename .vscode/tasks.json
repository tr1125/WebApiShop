{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run API",
      "type": "shell",
      "command": "dotnet run",
      "options": {
        "cwd": "${workspaceFolder}/WebApiShop/WebApiShop"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "dotnet",
        "pattern": "$msCompile",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "Now listening on:"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always"
      }
    },
    {
      "label": "Run Angular",
      "type": "shell",
      "command": "ng serve -o",
      "options": {
        "cwd": "${workspaceFolder}/ClientApp"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "bundle generation complete"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always"
      }
    },
    {
      "label": "Run Full Stack",
      "dependsOn": ["Run API", "Run Angular"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
